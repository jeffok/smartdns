# ==========================================
# SmartDNS 环境变量完整说明
# 复制为 .env 后按需修改，不填的变量均使用内置默认值
# ==========================================

# --- DNS 上游（逗号分隔，支持 IP:PORT）---

# 国内 DNS（-group cn），不参与默认查询，仅匹配域名命中时使用
# DNS_CN=119.29.29.29,114.114.114.114

# 全球 DNS（-group global），同时也是未匹配域名的默认上游
# DNS_GLOBAL=8.8.8.8,1.1.1.1

# AI 域名专用 DNS（-group ai），如有独立 AI 专线在此填写
# DNS_AI=   # 填写 AI 专线 DNS IP，如新加坡隧道 10.254.0.2


# --- ECS（EDNS Client Subnet，CDN 节点优选）---
# 让上游 CDN 返回指定地区的节点。留空=不启用。
# 海外回国: ECS_PRESET=119.29.29.29  → 告诉 CDN 你在中国
# 国内出国: ECS_PRESET=8.8.8.8       → 告诉 CDN 你在海外
# ECS_PRESET=202.96.134.0/24  # 深圳电信（推荐，CDN 调度为广东电信节点）


# --- 容器内部 DNS（下载规则、解析 AI 域名时使用）---
# 默认 8.8.8.8，确保即使 DNS_GLOBAL 是国内 IP 也能访问 GitHub
# CONTAINER_DNS=8.8.8.8


# --- RouterOS AI 同步（可选）---
# 配置后 sync-ai.sh 每 30 分钟将 AI 域名解析结果写入 ROS ai-sgp 地址列表
# ROS_HOST 留空即完全关闭 RouterOS 同步
# ROS_HOST=
# ROS_USER=admin
# ROS_PASS=


# --- 通用 ---
# TZ=Asia/Shanghai
