# ==========================================
# SmartDNS 环境变量完整说明
# 复制为 .env 后按需修改
# ==========================================

# --- DNS 上游（逗号分隔，支持 IP:PORT）---

# 国内 DNS（对应 -group cn）
DNS_CN=119.29.29.29,223.5.5.5,114.114.114.114

# 全球 DNS（对应 -group global，也是未匹配域名的默认上游）
DNS_GLOBAL=1.1.1.1,8.8.8.8,9.9.9.9

# AI 域名专用 DNS（对应 -group ai，留空则复用 DNS_GLOBAL）
# 如有独立 AI 专线/通道，在此填写专用 DNS
# DNS_AI=10.100.89.3


# --- ECS（EDNS Client Subnet，CDN 优化）---

# ECS_PRESET：向上游 DNS 发送的伪 IP 段，让 CDN 返回目标地区附近的节点
#   海外回国: ECS_PRESET=119.29.29.29  → 上游认为你在中国
#   国内出国: ECS_PRESET=8.8.8.8      → 上游认为你在海外
#   留空则不启用 ECS
# ECS_PRESET=119.29.29.29


# --- 容器内部 DNS ---

# CONTAINER_DNS：容器内 curl/wget/nslookup 等工具使用的 DNS
# 用于下载规则（GitHub）和解析 AI 域名。
# 默认 8.8.8.8，确保即使 DNS_GLOBAL 为国内 IP 也能访问 GitHub。
CONTAINER_DNS=8.8.8.8


# --- RouterOS AI 同步（可选功能） ---
# 以下三项都配置后，sync-ai.sh 会将 AI 域名的解析结果实时写入
# RouterOS 的 ai-sgp address-list，使策略路由可据此强制走指定出口

# ROS_HOST：RouterOS 的 LAN IP（REST API 走 HTTP 80，需启用 www 服务）
# 留空则完全关闭 RouterOS 同步（仅本地刷新 ai-list）
# ROS_HOST=192.168.88.254

# ROS_USER：RouterOS REST API 用户名（默认 admin）
# ROS_USER=admin

# ROS_PASS：RouterOS 密码
# ROS_PASS=


# --- AI 列表源 ---

# AI_LIST_URL：AI 域名列表远端地址（支持 | 分隔多源镜像）
# 默认：GitHub mosdns 项目中的 ai-list.txt
# AI_LIST_URL=https://raw.githubusercontent.com/jeffok/mosdns/main/rules/ai-list.txt|https://gh-proxy.com/...

# RELOAD_ON_AI_LIST_CHANGE：远端 ai-list 变更后是否自动重载 SmartDNS
# 1 = 是（默认），0 = 否
# RELOAD_ON_AI_LIST_CHANGE=1


# --- 通用 ---

# 容器时区
TZ=Asia/Shanghai

# 规则文件最长保留时间（秒），超过则触发更新。0 为每次强制下载
# RULE_FILE_MAX_AGE=82800
